# Streamlit host port on your machine
STREAMLIT_PORT=8501

# Runtime behavior
LOG_LEVEL=INFO
LOOKBACK_DAYS_DEFAULT=30
MIN_VOLUME_DEFAULT=100
MAX_MARKETS_DEFAULT=80
SKIP_STARTUP_CHECKS=false

# Optional proxy settings (set only if your network requires them)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
